# BACSWN SkyWatch Bahamas — Environment Variables (EXAMPLE — copy to .env and fill in real values)
HOST=0.0.0.0
PORT=8060

# JWT — set to a strong random value in production (e.g. `openssl rand -hex 32`)
# If unset, the app generates and persists a key to data/secret.key (acceptable for dev)
JWT_SECRET=REPLACE_WITH_64_CHAR_HEX_SECRET
JWT_EXPIRY_HOURS=24

# First-run bootstrap: if the database has no users AND this var is set (min 12 chars),
# an admin account is created with this password. Unset immediately after first boot.
BACSWN_BOOTSTRAP_PASSWORD=

# OpenSky Network (optional — works without auth at lower rate limits)
OPENSKY_USERNAME=
OPENSKY_PASSWORD=

# Tomorrow.io (optional — for extended forecast data)
TOMORROW_API_KEY=

# Anthropic (for AI SIGMET generation / chat)
ANTHROPIC_API_KEY=
