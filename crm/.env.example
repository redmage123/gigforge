# CRM Platform — Environment Variables
# cp .env.example .env  →  fill in values before running docker compose up

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=crm_db
POSTGRES_USER=crm_user
POSTGRES_PASSWORD=changeme

# Convenience DSN — built dynamically by config.py from the vars above.
# Shown here for tools/scripts that expect a single DATABASE_URL.
# DATABASE_URL=postgresql+asyncpg://crm_user:changeme@db:5432/crm_db

# ── FastAPI / JWT ─────────────────────────────────────────────────────────────
# Generate a strong key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme-use-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS — comma-separated allowed origins ────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:8070,http://localhost:5173

# ── pgAdmin 4 ─────────────────────────────────────────────────────────────────
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=changeme

# ── Ports (optional overrides for host-level port mapping) ────────────────────
BACKEND_PORT=8070
PGADMIN_PORT=5050

# ── Application ───────────────────────────────────────────────────────────────
ENV=development
