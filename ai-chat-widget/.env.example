# Server
NODE_ENV=development
PORT=3000

# Database (PostgreSQL + pgvector)
DATABASE_URL=postgresql://chatuser:chatpassword@localhost:5432/chatwidget
DB_HOST=localhost
DB_PORT=5432
DB_NAME=chatwidget
DB_USER=chatuser
DB_PASSWORD=chatpassword

# OpenAI (leave blank to use mock client)
OPENAI_API_KEY=

# JWT
JWT_SECRET=change-this-secret-in-production-use-at-least-32-chars
JWT_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=*
