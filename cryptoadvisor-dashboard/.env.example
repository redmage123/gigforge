# CryptoAdvisor Dashboard Configuration
# Copy to .env and fill in optional values

# Server
HOST=0.0.0.0
PORT=8050

# CoinGecko API (optional — free tier works without key, but rate-limited)
COINGECKO_API_KEY=

# CryptoPanic news API key (optional — get from https://cryptopanic.com/developers/api/)
CRYPTOPANIC_API_KEY=

# Solana RPC (optional — default: public mainnet beta)
SOLANA_RPC=https://api.mainnet-beta.solana.com

# Agent memory directory (default: ../../memory relative to this app)
MEMORY_DIR=
